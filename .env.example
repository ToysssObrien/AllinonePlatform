# OmniDesk — Environment Variables Template
# Copy this file to .env for local development.
# For production (Render), set these in the Render dashboard Environment tab.

# ─── Data Storage ─────────────────────────────────────────────────────────────
# Local: leave blank (defaults to project data/ folder)
# Render: set to /var/data (the persistent disk mount path)
DATA_DIR=

# ─── Admin Credentials ────────────────────────────────────────────────────────
# Username and password for the OmniDesk login page.
# CHANGE THESE before deploying to production!
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=123456
ADMIN_DISPLAY_NAME=Admin

# ─── Facebook Integration ──────────────────────────────────────────────────────
# From Facebook Developer Console → Your App → Basic Settings
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret

# A random secret string you choose — must match what you set in the
# Facebook Webhook configuration page.
FB_VERIFY_TOKEN=omnidesk_fb_verify

# ─── App URLs ─────────────────────────────────────────────────────────────────
# The public-facing URL of this OmniDesk deployment.
# Local dev with ngrok: https://xxxx.ngrok-free.dev
# Render production:    https://omnidesk.onrender.com

# Used for Facebook Webhook callback URL (must be HTTPS and publicly accessible)
OMNIDESK_BASE_URL=http://127.0.0.1:8000

# Used for Facebook OAuth callback redirect (must match the Redirect URI in your Facebook App)
OMNIDESK_OAUTH_BASE_URL=http://127.0.0.1:8000

# Used to redirect the browser back after Facebook OAuth completes
OMNIDESK_UI_REDIRECT_URL=http://127.0.0.1:8000

# Optional local/demo mode. Leave unset in production so sample Support 1-6
# accounts are not created automatically.
# OMNIDESK_SEED_DEMO=1
